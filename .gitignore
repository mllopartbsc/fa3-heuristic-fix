# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
env/
venv/
.env
.venv*/
build/
dist/
*.egg-info/

# CUDA/C++
*.o
*.so
*.obj

# Editor
.vscode/
.idea/
*.swp
*.swo

# Logs
*.log
*.err
*.out

# Scratch results (regenerated by running experiments)
results/**
!results/.gitkeep
!results/README.md
# Allow committed published results
!results/published/
!results/published/**/*.json
!results/published/**/*.tex

# Flash Attention clone (downloaded by setup script — too large to track)
flash-attention/

# Pre-installed vLLM (from preinstall_vllm.sh)
vllm_latest/

# Large binary artifacts
*.sif
*.whl

# Build artifacts
.pydeps/
builds/
artifacts/
tmp_singularity/

# Temporary files
temp_*.json
temp_*.txt

# Misplaced job outputs (should be under results/ at repo root)
scripts/results/
